def sanitize_xml_text(value: Any) -> str:
    if value is None:
        return ""
    if not isinstance(value, str):
        value = str(value)

    cleaned: list[str] = []
    for char in value:
        if is_valid_xml_char(ord(char)):
            cleaned.append(char)
    return "".join(cleaned)


